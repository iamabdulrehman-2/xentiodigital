# ===============================
# Contact form email configuration
# ===============================

# SMTP server (Gmail defaults)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Sender account used by Nodemailer
# For Gmail, EMAIL is your full Gmail address
EMAIL=your-gmail@gmail.com

# For Gmail, PASSWORD must be a Google App Password (not your normal Gmail password)
PASSWORD=your-16-char-app-password

# Inbox where contact submissions should be sent
CONTACT_ADMIN_EMAIL=admin@yourdomain.com

# Optional "from" display in outgoing mail
FROM_NAME=Xentio Digital
FROM_EMAIL=your-gmail@gmail.com
